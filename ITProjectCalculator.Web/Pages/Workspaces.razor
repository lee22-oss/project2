@page "/workspaces"
@using ITProjectCalculator.Services.Interfaces
@using ITProjectCalculator.Data.Entities
@inject IWorkspaceService WorkspaceService
@inject IAuthenticationService AuthService

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Workspaces</h2>
        </div>
        <div class="col-md-4 text-end">
            <button class="btn btn-primary" @onclick="OpenCreateModal">+ Create Workspace</button>
        </div>
    </div>

    @if (workspaces == null)
    {
        <div class="alert alert-info">Loading workspaces...</div>
    }
    else if (workspaces.Count == 0)
    {
        <div class="alert alert-warning">No workspaces found.</div>
    }
    else
    {
        <div class="row">
            @foreach (var workspace in workspaces)
            {
                <div class="col-md-6 mb-3">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title">@workspace.Name</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Subdomain:</strong> @workspace.Subdomain</p>
                            <p><strong>Projects:</strong> @workspace.ProjectIds.Count</p>
                            <p><strong>Members:</strong> @workspace.UsersWithPermissions.Count</p>
                        </div>
                        <div class="card-footer">
                            <button class="btn btn-sm btn-info" @onclick="() => EditWorkspace(workspace)">Edit</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteWorkspace(workspace.Id)">Delete</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div class="modal fade" id="workspaceModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@(editingWorkspace?.Id > 0 ? "Edit Workspace" : "Create Workspace")</h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <div class="modal-body">
                @if (editingWorkspace != null)
                {
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input type="text" class="form-control" @bind="editingWorkspace.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Subdomain</label>
                        <input type="text" class="form-control" @bind="editingWorkspace.Subdomain" />
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="CloseModal">Close</button>
                <button type="button" class="btn btn-primary" @onclick="SaveWorkspace">Save</button>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Workspace>? workspaces;
    private Workspace? editingWorkspace;

    protected override async Task OnInitializedAsync()
    {
        var currentUser = await AuthService.GetCurrentUserAsync();
        if (currentUser?.Roles.Contains("GlobalAdmin") != true)
        {
            return;
        }
        await LoadWorkspaces();
    }

    private async Task LoadWorkspaces()
    {
        workspaces = await WorkspaceService.GetAllWorkspacesAsync();
    }

    private void OpenCreateModal()
    {
        editingWorkspace = new Workspace();
    }

    private void EditWorkspace(Workspace workspace)
    {
        editingWorkspace = new Workspace
        {
            Id = workspace.Id,
            Name = workspace.Name,
            Subdomain = workspace.Subdomain,
            AdminId = workspace.AdminId,
            UsersWithPermissions = new Dictionary<int, string>(workspace.UsersWithPermissions),
            ProjectIds = new List<int>(workspace.ProjectIds)
        };
    }

    private async Task SaveWorkspace()
    {
        if (editingWorkspace == null) return;

        if (editingWorkspace.Id > 0)
        {
            await WorkspaceService.UpdateWorkspaceAsync(editingWorkspace);
        }
        else
        {
            var currentUser = await AuthService.GetCurrentUserAsync();
            editingWorkspace.AdminId = currentUser?.Id ?? 0;
            await WorkspaceService.CreateWorkspaceAsync(editingWorkspace);
        }
        await LoadWorkspaces();
        editingWorkspace = null;
    }

    private async Task DeleteWorkspace(int id)
    {
        if (await WorkspaceService.DeleteWorkspaceAsync(id))
        {
            await LoadWorkspaces();
        }
    }

    private void CloseModal()
    {
        editingWorkspace = null;
    }
}
